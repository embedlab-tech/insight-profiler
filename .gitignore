# =============================================================================
# Insight Profiler — .gitignore
# EmbedLab-Tech | macOS / ESP-IDF / Python / Node.js
# =============================================================================

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── IDEs & Editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── ESP-IDF / CMake Build ────────────────────────────────────────────────────
build/
sdkconfig
sdkconfig.old
managed_components/
dependencies.lock

# ── C/C++ Objects & Binaries ─────────────────────────────────────────────────
*.o
*.ko
*.obj
*.elf
*.ilk
*.map
*.exp
*.gch
*.pch
*.lib
*.a
*.la
*.lo
*.dll
*.so
*.so.*
*.dylib
*.exe
*.out
*.app
*.hex
*.bin
*.dSYM/
*.su
*.idb
*.pdb
*.d
*.dwo

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
venv/
.venv/
.python-version
*.whl

# ── Node.js / TypeScript ────────────────────────────────────────────────────
node_modules/
sdk-js/dist/
*.tsbuildinfo
.npm
.yarn/

# ── Testing & Coverage ──────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ── Logs & Misc ─────────────────────────────────────────────────────────────
*.log
*.csv
*.sqlite
*.db
