{
  "name": "@embedlab-tech/insight-profiler",
  "version": "0.1.0",
  "description": "WebUSB SDK for the Insight Profiler power measurement tool by EmbedLab-Tech",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "biome ci . && tsc --noEmit && vitest run"
  },
  "keywords": [
    "webusb",
    "power-profiler",
    "embedded",
    "iot",
    "esp32"
  ],
  "author": "EmbedLab-Tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EmbedLab-Tech/insight-profiler"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "tsup": "^8.3",
    "typescript": "^5.7",
    "vitest": "^3.0"
  }
}
